---
layout: layouts/base.vto
---

<main>
  <article>
    <div class="article-top">
      <div>{{ include "time.vto" { date: page.date } }}</div>
      <h1>{{ title }}</h1>
      {{ include "tags.vto" { tags: tags } }}
    </div>
    <div id="article-content">{{ content }}</div>
  </article>
</main>
